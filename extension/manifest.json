{
  "manifest_version": 3,
  "name": "DailyDict Vocab",
  "version": "1.0.0",
  "description": "Lưu và ôn tập từ vựng từ DailyDictation.com",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://dailydictation.com/*"],
  "content_scripts": [{
    "matches": ["https://dailydictation.com/*"],
    "js": [
      "shared/badges.js",
      "shared/tags.js",
      "shared/storage.js",
      "shared/api.js",
      "content/tooltip.js",
      "content/content.js"
    ],
    "css": ["content/tooltip.css"]
  }],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/v2_icon16.png",
      "48": "icons/v2_icon16.png",
      "128": "icons/v2_icon16.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "web_accessible_resources": [{
    "resources": ["webapp/*"],
    "matches": ["<all_urls>"]
  }]
}